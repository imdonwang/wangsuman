":{"uuid":"1a6382d8-cc22-4549-abae-199095c15a50"},"vjsthasia-2575":{"uuid":"1fccb436-2031-4317-8fe1-f39a106a753c"},"VJEASTASIA-1738":{"uuid":"3538db7d-55bb-4cad-9a78-0e5bdd64ea86"},"VJEASTASIA-1735":{"uuid":"9de34bdd-2f62-4031-af65-0e3455e955e2"},"vjsthasia-2480":{"uuid":"867ff01b-7bb0-4bed-ae0b-fc8da731cc31"},"vjsthasia-2468":{"uuid":"836f794b-00aa-4861-8354-2021635dd5b5"},"vjeastasia-00001":{"uuid":"c7e2c14b-8174-49a6-89d9-cf4353d11299"},"vjeastasia-00002":{"uuid":"2b706511-04af-4776-8e44-8e940c9cde2c"},"vjeastasia-00003":{"uuid":"8a0d7d33-a4d0-4a27-9195-f0354b5ff050"},"VJEASTASIA-1548":{"uuid":"d2e181ca-84cf-47d4-915e-081f468a10da"},"VJEUROPE-946":{"uuid":"272be499-fc8a-4552-adf7-01dd7df97cc0"},"VJNEAREAST-1129":{"uuid":"4a4cfa43-3763-486f-b84a-3097d98daa36"},"newsspec-36307":{"uuid":"f5b7c669-3fb9-4b7c-bfdc-01a6c1cea045"}},"publication_date_iso":"2024-02-23T12:26:58.687Z","pathToWrapperAssets":"https://news.files.bbci.co.uk/include/newsspec/37995-timeline-factory-revamped/assets/embed","pathToInclude":"https://news.files.bbci.co.uk/include/newsspec/37995-timeline-factory-revamped/zhongwen_trad/VJEASTASIA-1697/embed","pathToWrapperAssetsToInclude":"https://news.files.bbci.co.uk/include/newsspec/37995-timeline-factory-revamped/zhongwen_trad/VJEASTASIA-1697/embed"};
